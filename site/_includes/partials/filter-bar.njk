<div class="filters">
  <div class="search-box">
    <input type="text" id="search-input" placeholder="Search by name, skill, framework..." aria-label="Search engineers">
  </div>

  <div id="active-filters-summary" class="active-filters-summary" style="display:none">
    <span class="active-filters-label">Filters:</span>
    <div id="active-filter-pills" class="active-filter-pills"></div>
    <button id="clear-filters" class="btn-clear">Clear all</button>
  </div>

  <div class="filter-groups">
    <div class="filter-group" data-group="specializations">
      <button class="filter-group-header" aria-expanded="false">
        <svg class="chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        <span>Specializations</span>
        <span class="count-badge" style="display:none">0</span>
      </button>
      <div class="filter-chips" data-filter="specializations">
        {% set allSpecs = collections.engineers | uniqueValues("specializations") %}
        {% for spec in allSpecs %}
        <button class="chip" data-value="{{ spec | lower }}" aria-pressed="false">{{ spec }}</button>
        {% endfor %}
      </div>
    </div>

    <div class="filter-group" data-group="frameworks">
      <button class="filter-group-header" aria-expanded="false">
        <svg class="chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        <span>Frameworks</span>
        <span class="count-badge" style="display:none">0</span>
      </button>
      <div class="filter-chips" data-filter="frameworks">
        {% set allFrameworks = collections.engineers | uniqueValues("frameworks") %}
        {% for fw in allFrameworks %}
        <button class="chip" data-value="{{ fw | lower }}" aria-pressed="false">{{ fw }}</button>
        {% endfor %}
      </div>
    </div>

    <div class="filter-group" data-group="certifications">
      <button class="filter-group-header" aria-expanded="false">
        <svg class="chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        <span>Certifications</span>
        <span class="count-badge" style="display:none">0</span>
      </button>
      <div class="filter-chips" data-filter="certifications">
        {% set allCerts = collections.engineers | uniqueValues("certifications") %}
        {% for cert in allCerts %}
        <button class="chip" data-value="{{ cert | lower }}" aria-pressed="false">{{ cert }}</button>
        {% endfor %}
      </div>
    </div>

    <div class="filter-group" data-group="languages">
      <button class="filter-group-header" aria-expanded="false">
        <svg class="chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        <span>Languages & Tools</span>
        <span class="count-badge" style="display:none">0</span>
      </button>
      <div class="filter-chips" data-filter="languages">
        {% set allLanguages = collections.engineers | uniqueValues("languages") %}
        {% for lang in allLanguages %}
        <button class="chip" data-value="{{ lang | lower }}" aria-pressed="false">{{ lang }}</button>
        {% endfor %}
      </div>
    </div>

    <div class="filter-group" data-group="available">
      <button class="filter-group-header" aria-expanded="false">
        <svg class="chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        <span>Available For</span>
        <span class="count-badge" style="display:none">0</span>
      </button>
      <div class="filter-chips" data-filter="available">
        {% set allAvailable = collections.engineers | uniqueValues("available_for") %}
        {% for a in allAvailable %}
        <button class="chip" data-value="{{ a | lower }}" aria-pressed="false">{{ a }}</button>
        {% endfor %}
      </div>
    </div>
  </div>
</div>
